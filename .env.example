# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit actual secrets.

# LLM API key (required)
LLM_API_KEY=sk-...

# Embedding API key — often the same as LLM_API_KEY
EMBED_API_KEY=sk-...

# Chainlit session secret — generate with: chainlit create-secret
CHAINLIT_AUTH_SECRET=...

# Optional: Tavily internet search
# TAVILY_API_KEY=tvly-...

# Optional: Mem0 Cloud instead of local ChromaDB
# MEM0_API_KEY=m0-...
